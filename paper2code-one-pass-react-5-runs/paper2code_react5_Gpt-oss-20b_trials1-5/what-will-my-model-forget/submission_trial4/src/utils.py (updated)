# src/utils.py
import random
import numpy as np
import torch
from transformers import (
    BartTokenizer,
    BartForConditionalGeneration,
    T5Tokenizer,
    T5ForConditionalGeneration,
)
from datasets import load_dataset
from tqdm import tqdm

# --------------------------------------------------------------------------- #
#                         Utility helpers                                    #
# --------------------------------------------------------------------------- #
def set_seed(seed: int = 42):
    """Set random seeds for reproducibility."""
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)


def load_model_and_tokenizer(model_name: str, device: torch.device):
    """Return tokenizer and model on the requested device."""
    if "bart" in model_name.lower():
        tokenizer = BartTokenizer.from_pretrained(model_name)
        model = BartForConditionalGeneration.from_pretrained(model_name).to(device)
    elif "t5" in model_name.lower():
        tokenizer = T5Tokenizer.from_pretrained(model_name)
        model = T5ForConditionalGeneration.from_pretrained(model_name).to(device)
    else:
        raise ValueError(f"Unsupported model: {model_name}")
    return tokenizer, model


def encode_example(example, tokenizer, max_length=512):
    """
    Tokenise a single example.
    example: dict with keys 'input' and 'output'.
    Returns a dict suitable for the model.
    """
    inputs = tokenizer(
        example["input"],
        padding="max_length",
        truncation=True,
        max_length=max_length,
        return_tensors="pt",
    )
    with tokenizer.as_target_tokenizer():
        labels = tokenizer(
            example["output"],
            padding="max_length",
            truncation=True,
            max_length=max_length,
            return_tensors="pt",
        )
    inputs["labels"] = labels["input_ids"]
    return inputs


def train_one_epoch(model, dataloader, optimizer, device, grad_accum=1):
    model.train()
    total_loss = 0.0
    optimizer.zero_grad()
    for step, batch in enumerate(dataloader):
        batch = {k: v.to(device) for k, v in batch.items()}
        outputs = model(**batch)
        loss = outputs.loss
        loss = loss / grad_accum
        loss.backward()
        if (step + 1) % grad_accum == 0:
            optimizer.step()
            optimizer.zero_grad()
        total_loss += loss.item() * grad_accum
    return total_loss / len(dataloader)


def evaluate_example(model, tokenizer, example, device):
    """
    Generate a single prediction and compare to the gold output.
    Returns (prediction_str, target_str, is_correct)
    """
    model.eval()
    inputs = encode_example(example, tokenizer)
    inputs = {k: v.to(device) for k, v in inputs.items()}
    with torch.no_grad():
        generated_ids = model.generate(
            input_ids=inputs["input_ids"],
            attention_mask=inputs["attention_mask"],
            max_new_tokens=128,
            num_beams=5,
            early_stopping=True,
        )
    pred_str = tokenizer.decode(generated_ids[0], skip_special_tokens=True).strip()
    target_str = example["output"].strip()
    is_correct = pred_str == target_str
    return pred_str, target_str, is_correct


def compute_em(preds, targets):
    """Exact Match (EM) score: fraction of exact matches."""
    correct = sum(p.strip() == t.strip() for p, t in zip(preds, targets))
    return correct / len(preds) if preds else 0.0


def get_encoder_embedding(model, tokenizer, example, device):
    """
    Return the mean encoder hidden state for the input side of the example.
    """
    model.eval()
    with torch.no_grad():
        enc_inputs = tokenizer(
            example["input"],
            return_tensors="pt",
            truncation=True,
            max_length=512,
        ).to(device)
        enc_outputs = model.get_encoder()(enc_inputs["input_ids"], attention_mask=enc_inputs["attention_mask"])
        emb = enc_outputs.last_hidden_state.mean(dim=1).squeeze(0)  # [hidden_dim]
    return emb.cpu()


def get_representation_raw(model, tokenizer, example, device):
    """
    Return a raw representation vector for the full input–output pair.
    It concatenates the mean encoder hidden state of the input and the
    mean encoder hidden state of the output (tokenised with the target tokenizer).
    """
    model.eval()
    with torch.no_grad():
        # Input representation
        enc_inputs = tokenizer(
            example["input"],
            return_tensors="pt",
            truncation=True,
            max_length=512,
        ).to(device)
        enc_outputs = model.get_encoder()(enc_inputs["input_ids"], attention_mask=enc_inputs["attention_mask"])
        inp_emb = enc_outputs.last_hidden_state.mean(dim=1).squeeze(0)

        # Output representation (using target tokenizer)
        out_inputs = tokenizer(
            example["output"],
            return_tensors="pt",
            truncation=True,
            max_length=512,
        ).to(device)
        out_outputs = model.get_encoder()(out_inputs["input_ids"], attention_mask=out_inputs["attention_mask"])
        out_emb = out_outputs.last_hidden_state.mean(dim=1).squeeze(0)

        raw_rep = torch.cat([inp_emb, out_emb], dim=-1)  # [2*hidden_dim]
    return raw_rep.cpu()


def load_p3_subset(num_examples=200, seed=42):
    """
    Load a small subset of the P3 training data.
    Each example is converted to {'input': prompt, 'output': answer}.
    """
    ds = load_dataset("p3", split="train")
    ds = ds.shuffle(seed=seed).select(range(num_examples))
    examples = []
    for ex in ds:
        # P3 format: 'prompt', 'output', but some tasks may have 'output' as list
        output = ex["output"]
        if isinstance(output, list):
            output = output[0] if output else ""
        examples.append({"input": ex["prompt"], "output": output})
    return examples


def load_mmlu_subset(num_examples=10, seed=42):
    """
    Load a small subset of the MMLU validation data.
    Each example is converted to {'input': question + choices, 'output': correct answer letter}.
    """
    ds = load_dataset("mmlu", split="validation")
    ds = ds.shuffle(seed=seed).select(range(num_examples))
    examples = []
    for ex in ds:
        # MMLU format: 'question', 'choices', 'answerKey'
        question = ex["question"]
        choices = ex["choices"]
        # Build input string
        choice_str = " ".join([f"{k}. {v}" for k, v in zip(choices["label"], choices["text"])])
        inp = f"Question: {question} Choices: {choice_str}"
        out = ex["answerKey"]  # e.g., 'A', 'B', ...
        examples.append({"input": inp, "output": out})
    return examples