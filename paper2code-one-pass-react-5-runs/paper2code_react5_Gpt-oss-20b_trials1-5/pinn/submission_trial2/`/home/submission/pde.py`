#!/usr/bin/env python3
"""
Definitions of PDEs, boundary/initial operators, exact solutions and
sampling utilities.
"""

import torch
import numpy as np
from typing import Tuple, Dict, List


class PDE:
    """
    Wrapper that provides
        * residual operator 𝒟(u, x, t)
        * boundary operator ℬ(u, x, t)
        * initial operator 𝔅₀(u, x, t)
        * exact solution (for L2RE)
        * source / coefficient parameters
    """

    def __init__(self, name: str):
        self.name = name.lower()
        if self.name == "convection":
            self.beta = 40.0
        elif self.name == "reaction":
            self.rho = 5.0
        elif self.name == "wave":
            self.beta = 5.0
        else:
            raise ValueError(f"Unknown PDE {name}")

    # --------------------------------------------------------------------- #
    # Residual operator 𝒟
    # --------------------------------------------------------------------- #
    def residual(
        self,
        u: torch.Tensor,
        x: torch.Tensor,
        t: torch.Tensor,
    ) -> torch.Tensor:
        """
        Computes residual values for all points.
        u: (N,) predictions
        x, t: (N,) coordinates
        """
        # Enable gradient tracking for x and t
        x = x.clone().requires_grad_(True)
        t = t.clone().requires_grad_(True)

        # First derivatives
        u_t = torch.autograd.grad(u, t, grad_outputs=torch.ones_like(u), create_graph=True)[0]
        u_x = torch.autograd.grad(u, x, grad_outputs=torch.ones_like(u), create_graph=True)[0]

        if self.name == "convection":
            return u_t + self.beta * u_x
        elif self.name == "reaction":
            return u_t - self.rho * u * (1 - u)
        elif self.name == "wave":
            # Second derivatives
            u_tt = torch.autograd.grad(u_t, t, grad_outputs=torch.ones_like(u_t), create_graph=True)[0]
            u_xx = torch.autograd.grad(u_x, x, grad_outputs=torch.ones_like(u_x), create_graph=True)[0]
            return u_tt - 4.0 * u_xx
        else:
            raise RuntimeError("Unreachable")

    # --------------------------------------------------------------------- #
    # Boundary operator ℬ
    # --------------------------------------------------------------------- #
    def boundary(
        self,
        u: torch.Tensor,
        x: torch.Tensor,
        t: torch.Tensor,
    ) -> torch.Tensor:
        """
        Returns residuals at boundary points.
        For periodic problems: u(0,t)-u(2π,t) or u(0,t)-u(2π,t)
        For Dirichlet: u(0,t), u(1,t)
        """
        if self.name in ["convection", "reaction"]:
            # periodic boundaries at x=0 and x=2π
            return u  # will be used with appropriate pairing outside
        elif self.name == "wave":
            # Dirichlet zero
            return u
        else:
            raise RuntimeError("Unreachable")

    # --------------------------------------------------------------------- #
    # Initial condition operator 𝔅₀
    # --------------------------------------------------------------------- #
    def initial(
        self,
        u: torch.Tensor,
        x: torch.Tensor,
        t: torch.Tensor,
    ) -> torch.Tensor:
        """
        Returns residuals at initial time t=0.
        """
        if self.name == "convection":
            exact = torch.sin(x)
        elif self.name == "reaction":
            h = torch.exp(-((x - np.pi) ** 2) / (2 * (np.pi / 4) ** 2))
            exact = h
        elif self.name == "wave":
            exact = torch.sin(np.pi * x) + 0.5 * torch.sin(self.beta * np.pi * x)
        else:
            raise RuntimeError("Unreachable")
        return u - exact

    # --------------------------------------------------------------------- #
    # Exact solution (for L2RE)
    # --------------------------------------------------------------------- #
    def exact_solution(self, x: torch.Tensor, t: torch.Tensor) -> torch.Tensor:
        if self.name == "convection":
            return torch.sin(x - self.beta * t)
        elif self.name == "reaction":
            h = torch.exp(-((x - np.pi) ** 2) / (2 * (np.pi / 4) ** 2))
            return h * torch.exp(self.rho * t) / (
                h * torch.exp(self.rho * t) + 1 - h
            )
        elif self.name == "wave":
            return (
                torch.sin(np.pi * x) * torch.cos(2 * np.pi * t)
                + 0.5 * torch.sin(self.beta * np.pi * x) * torch.cos(2 * self.beta * np.pi * t)
            )
        else:
            raise RuntimeError("Unreachable")

    # --------------------------------------------------------------------- #
    # Data generation utilities
    # --------------------------------------------------------------------- #
    def build_dataset(
        self,
        residual_pts: int,
        grid_x: int,
        grid_t: int,
        init_pts: int,
        boundary_pts: int,
    ) -> Dict[str, torch.Tensor]:
        """
        Returns a dictionary with tensors:
            - res_x, res_t: residual point coordinates
            - init_x, init_t: initial condition points
            - bnd_x, bnd_t, bnd_type: boundary points
            - full_x, full_t: grid for evaluation (L2RE)
        All tensors are on CPU (they will be moved to device in training).
        """
        # Residual points: random subset from grid
        xs = torch.linspace(0, self._x_max(), steps=grid_x)
        ts = torch.linspace(0, 1.0, steps=grid_t)
        xv, tv = torch.meshgrid(xs, ts, indexing="ij")
        grid = torch.stack([xv.reshape(-1), tv.reshape(-1)], dim=1)
        idx = torch.randperm(grid.shape[0])[:residual_pts]
        res_x, res_t = grid[idx, 0], grid[idx, 1]

        # Initial condition points (t=0)
        init_x = torch.linspace(0, self._x_max(), steps=init_pts)
        init_t = torch.zeros_like(init_x)

        # Boundary points
        if self.name in ["convection", "reaction"]:
            # Periodic boundaries at x=0 and x=2π
            bnd_x_left = torch.zeros(boundary_pts)
            bnd_t_left = torch.linspace(0, 1.0, steps=boundary_pts)
            bnd_x_right = self._x_max() * torch.ones(boundary_pts)
            bnd_t_right = bnd_t_left.clone()
            bnd_x = torch.cat([bnd_x_left, bnd_x_right])
            bnd_t = torch.cat([bnd_t_left, bnd_t_right])
            # tag: 0 for left, 1 for right (used in loss)
            bnd_type = torch.cat([torch.zeros(boundary_pts, dtype=torch.int64),
                                  torch.ones(boundary_pts, dtype=torch.int64)])
        elif self.name == "wave":
            # Dirichlet zero at x=0 and x=1
            bnd_x_left = torch.zeros(boundary_pts)
            bnd_t_left = torch.linspace(0, 1.0, steps=boundary_pts)
            bnd_x_right = torch.ones(boundary_pts)
            bnd_t_right = bnd_t_left.clone()
            bnd_x = torch.cat([bnd_x_left, bnd_x_right])
            bnd_t = torch.cat([bnd_t_left, bnd_t_right])
            bnd_type = torch.cat([torch.zeros(boundary_pts, dtype=torch.int64),
                                  torch.ones(boundary_pts, dtype=torch.int64)])
        else:
            raise RuntimeError("Unreachable")

        # Full grid for evaluation
        full_x = torch.linspace(0, self._x_max(), steps=grid_x)
        full_t = torch.linspace(0, 1.0, steps=grid_t)
        full_xv, full_tv = torch.meshgrid(full_x, full_t, indexing="ij")
        full_x_flat = full_xv.reshape(-1)
        full_t_flat = full_tv.reshape(-1)

        return {
            "res_x": res_x,
            "res_t": res_t,
            "init_x": init_x,
            "init_t": init_t,
            "bnd_x": bnd_x,
            "bnd_t": bnd_t,
            "bnd_type": bnd_type,
            "full_x": full_x_flat,
            "full_t": full_t_flat,
        }

    def _x_max(self) -> float:
        if self.name in ["convection", "reaction"]:
            return 2 * np.pi
        elif self.name == "wave":
            return 1.0
        else:
            raise RuntimeError("Unreachable")