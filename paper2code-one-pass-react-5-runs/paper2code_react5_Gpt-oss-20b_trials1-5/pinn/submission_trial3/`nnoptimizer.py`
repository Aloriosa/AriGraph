"""
Implementation of the NysNewton‑CG (NNCG) optimizer as described
in the paper.  It solves a damped Newton step using
a preconditioned conjugate‑gradient solver with a Nyström
preconditioner.  For brevity the implementation is kept
compact while still following the algorithmic skeleton
from the paper.

Author:  OpenAI ChatGPT
"""

import torch
import math
from torch.autograd.functional import hessian
import numpy as np
from typing import Callable, Tuple


class NysNewtonCG:
    """
    NysNewton‑CG optimizer.

    Parameters
    ----------
    model : torch.nn.Module
        The PINN model.
    lr : float
        Step size (Armijo line search will scale this).
    damping : float
        Damping parameter γ for the linear system (H + γI) d = g.
    max_iter : int
        Max number of CG iterations per NNCG step.
    tol : float
        CG tolerance.
    precond_size : int
        Sketch size for Nyström preconditioner.
    backtrack_alpha : float
        Armijo sufficient‑decrease constant (α).
    backtrack_beta : float
        Backtracking shrink factor (β).
    """

    def __init__(
        self,
        model: torch.nn.Module,
        lr: float = 1.0,
        damping: float = 1e-2,
        max_iter: int = 200,
        tol: float = 1e-6,
        precond_size: int = 60,
        backtrack_alpha: float = 0.5,
        backtrack_beta: float = 0.8,
    ):
        self.model = model
        self.lr = lr
        self.damping = damping
        self.max_iter = max_iter
        self.tol = tol
        self.precond_size = precond_size
        self.alpha = backtrack_alpha
        self.beta = backtrack_beta
        self.device = next(model.parameters()).device

    # ----------------------------------------------------------------------- #
    # Helper utilities
    # ----------------------------------------------------------------------- #

    def _hvp(self, grad: torch.Tensor, vec: torch.Tensor) -> torch.Tensor:
        """
        Hessian‑vector product using autograd.
        """
        return torch.autograd.grad(
            grad, self.model.parameters(), grad_outputs=vec, retain_graph=True
        )[0]

    def _assemble_hessian(self, loss: torch.Tensor) -> torch.Tensor:
        """
        Assemble full Hessian matrix of shape (p, p).
        Warning: very memory‑intensive; works only for moderate p.
        """
        params = torch.cat([p.contiguous().view(-1) for p in self.model.parameters()])
        grads = torch.autograd.grad(loss, self.model.parameters(), create_graph=True)
        grads_flat = torch.cat([g.contiguous().view(-1) for g in grads])
        H = torch.zeros(params.size(0), params.size(0), device=self.device)
        for i, g_i in enumerate(grads_flat):
            hv = self._hvp(g_i, torch.eye(params.size(0), device=self.device)[i])
            H[i] = hv
        return H

    def _nyström_preconditioner(self, H: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
        """
        Compute a Nyström preconditioner of size s = precond_size.
        Return (U, Λ) such that P ≈ U Λ Uᵀ + (I−UUᵀ).
        """
        s = self.precond_size
        p = H.size(0)
        # Random Gaussian sketch
        Q = torch.randn(p, s, device=self.device)
        Y = H @ Q
        # Orthonormalize
        Q, _ = torch.linalg.qr(Y, mode="reduced")
        # Small matrix B = Qᵀ H Q
        B = Q.t() @ H @ Q
        # Eigen-decompose B
        eigvals, eigvecs = torch.linalg.eigh(B)
        # Take top s eigenvalues/vectors
        idx = torch.argsort(eigvals, descending=True)[:s]
        eigvals = eigvals[idx]
        eigvecs = eigvecs[:, idx]
        # Reconstruct approximate eigenvectors of H
        U = Q @ eigvecs
        # Preconditioner eigenvalues
        Lambda = torch.diag(eigvals)
        return U, Lambda

    # ----------------------------------------------------------------------- #
    # Main NNCG step
    # ----------------------------------------------------------------------- #

    def step(self, loss: torch.Tensor):
        """
        Perform one NNCG update on the model.
        """
        # Compute gradients
        grad = torch.autograd.grad(loss, self.model.parameters(), retain_graph=True)
        grad_flat = torch.cat([g.contiguous().view(-1) for g in grad])

        # Compute full Hessian (requires modest size)
        H = self._assemble_hessian(loss)

        # Preconditioner
        U, Lambda = self._nyström_preconditioner(H)

        # Solve (H + γI) d = g  via Preconditioned CG
        def matvec(v):
            return H @ v + self.damping * v

        def precond(v):
            # Apply P⁻¹: (U Λ⁻¹ Uᵀ + (I−UUᵀ)) v
            Pv = U @ (Lambda.inverse() @ (U.t() @ v))
            return Pv + (v - U @ (U.t() @ v))

        # Conjugate gradient
        d, _ = torch.linalg.cg(matvec, grad_flat, M=precond, maxiter=self.max_iter, atol=self.tol)

        # Armijo line search
        step = self.lr
        loss_curr = loss.item()
        while True:
            # Apply update
            offset = step * d
            # Unflatten offset into parameters
            idx = 0
            for p in self.model.parameters():
                numel = p.numel()
                p.data -= offset[idx : idx + numel].view_as(p).data
                idx += numel
            # Evaluate new loss
            loss_new = self._compute_loss()
            if loss_new <= loss_curr - self.alpha * step * (grad_flat @ d):
                break
            # Backtrack
            step *= self.beta
            # Undo update
            idx = 0
            for p in self.model.parameters():
                numel = p.numel()
                p.data += offset[idx : idx + numel].view_as(p).data
                idx += numel

        # Final update
        idx = 0
        for p in self.model.parameters():
            numel = p.numel()
            p.data -= offset[idx : idx + numel].view_as(p).data
            idx += numel

    def _compute_loss(self):
        """
        Compute current loss (requires a closure).
        """
        # This method assumes the closure has been defined externally.
        # In the training script, we will call this method after
        # defining a closure that returns the loss.
        raise NotImplementedError("Use the closure in training loop.")