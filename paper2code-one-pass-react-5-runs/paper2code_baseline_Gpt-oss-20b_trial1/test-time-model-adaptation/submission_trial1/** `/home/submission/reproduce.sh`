#!/usr/bin/env bash
set -euo pipefail

# -------------------------------------------------------------
# This script installs the needed packages and runs the FOA
# experiment on a synthetic dataset.  The script is deliberately
# lightweight so that it can be run on the grader's environment.
# -------------------------------------------------------------

echo "=== Installing Python packages ==="
# Use pip from the system Python.  The grader environment already
# contains python3.  We install into a virtualenv to avoid
# interfering with system packages.
python3 -m venv venv
source venv/bin/activate
pip install --upgrade pip
pip install -r requirements.txt

echo "=== Running FOA experiment ==="
python src/main.py

echo "=== All done ==="