class PPOAgent:
    def __init__(self, policy_net, value_net, cfg):
        self.cfg = cfg
        self.policy = policy_net.to(DEVICE)
        self.value = value_net.to(DEVICE)
        self.policy_optimizer = torch.optim.Adam(
            filter(lambda p: p.requires_grad, self.policy.parameters()), lr=cfg["lr"])
        self.value_optimizer = torch.optim.Adam(self.value.parameters(), lr=cfg["lr"])

    def collect_trajectory(self, env):
        obs, _ = env.reset(seed=SEED + random.randint(0, 10000))
        obs = torch.tensor(obs, dtype=torch.float32, device=DEVICE)

        states = []
        actions = []
        log_probs = []
        rewards = []
        dones = []
        values = []

        for _ in range(self.cfg["steps_per_task"] // len(env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env.env